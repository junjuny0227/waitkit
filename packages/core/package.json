{
  "name": "@waitkit/core",
  "version": "0.0.0",
  "description": "Development-only fetch interceptor for testing loading, error, and timeout states.",
  "type": "module",
  "license": "MIT",
  "author": "junjuny0227",
  "homepage": "https://github.com/junjuny0227/waitkit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/junjuny0227/waitkit.git"
  },
  "bugs": {
    "url": "https://github.com/junjuny0227/waitkit/issues"
  },
  "keywords": [
    "fetch",
    "network",
    "latency",
    "loading",
    "timeout",
    "testing"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@waitkit/eslint-config": "workspace:*",
    "@waitkit/typescript-config": "workspace:*",
    "eslint": "^9.39.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
