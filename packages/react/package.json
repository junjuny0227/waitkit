{
  "name": "@waitkit/react",
  "version": "0.4.0",
  "description": "React provider and hooks for Waitkit controllers.",
  "type": "module",
  "license": "MIT",
  "author": "junjuny0227",
  "homepage": "https://github.com/junjuny0227/waitkit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/junjuny0227/waitkit.git"
  },
  "bugs": {
    "url": "https://github.com/junjuny0227/waitkit/issues"
  },
  "keywords": [
    "react",
    "fetch",
    "network",
    "loading",
    "timeout",
    "testing"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@waitkit/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@waitkit/eslint-config": "workspace:*",
    "@waitkit/typescript-config": "workspace:*",
    "eslint": "^9.39.4",
    "jsdom": "^27.2.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
